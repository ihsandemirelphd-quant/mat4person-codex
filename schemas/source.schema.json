{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mat4person.org/schemas/source.schema.json",
  "title": "MAT4Person source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "title",
    "source_type",
    "access",
    "sha256",
    "language",
    "page_count",
    "content_kind",
    "ingest_version"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^source:[a-z0-9][a-z0-9_-]*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "source_type": {
      "enum": ["pdf", "image", "html", "docx", "other"]
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "uri"],
      "properties": {
        "kind": { "enum": ["public", "private", "local"] },
        "uri": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$"
    },
    "page_count": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "null" }
      ]
    },
    "content_kind": {
      "enum": ["plain_text", "markdown", "pdf_text", "ocr_text"]
    },
    "ingest_version": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "citation": { "type": "string" },
    "rights_note": { "type": "string" }
  }
}
