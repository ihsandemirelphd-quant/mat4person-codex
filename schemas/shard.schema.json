{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mat4person.org/schemas/shard.schema.json",
  "title": "MAT4Person isolated worker shard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "config_sha256",
    "shard_id",
    "source_id",
    "source_sha256",
    "worker_id",
    "status",
    "source",
    "source_text",
    "entities",
    "evidence",
    "relations"
  ],
  "properties": {
    "schema_version": { "const": "shard-v1" },
    "run_id": { "type": "string", "pattern": "^run:[a-z0-9][a-z0-9._-]*$" },
    "config_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "shard_id": { "type": "string", "pattern": "^shard:[a-z0-9][a-z0-9._-]*$" },
    "source_id": { "type": "string", "pattern": "^source:[a-z0-9][a-z0-9_-]*$" },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "worker_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "status": { "enum": ["READY", "FAILED"] },
    "source": { "type": "object" },
    "source_text": { "type": "object" },
    "entities": { "type": "array", "items": { "type": "object" } },
    "evidence": { "type": "array", "items": { "type": "object" } },
    "relations": { "type": "array", "items": { "type": "object" } },
    "error": { "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] }
  }
}
