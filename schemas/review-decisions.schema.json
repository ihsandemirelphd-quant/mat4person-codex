{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mat4person.org/schemas/review-decisions.schema.json",
  "title": "MAT4Person independent review decisions",
  "type": "object",
  "additionalProperties": false,
  "required": ["review_version", "run_id", "reviewer", "decisions"],
  "properties": {
    "review_version": { "const": "review-decisions-v1" },
    "run_id": { "type": "string", "pattern": "^run:[a-z0-9][a-z0-9._-]*$" },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "prompt_version", "worker_id"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "prompt_version": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "worker_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "response_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relation_id", "verdict"],
        "properties": {
          "relation_id": { "type": "string", "pattern": "^rel:[a-z0-9][a-z0-9:_-]*$" },
          "verdict": { "enum": ["accept", "reject", "review"] },
          "note": { "type": "string" }
        }
      }
    }
  }
}
