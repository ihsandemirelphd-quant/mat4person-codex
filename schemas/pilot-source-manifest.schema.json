{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mat4person.org/schemas/pilot-source-manifest.schema.json",
  "title": "MAT4Person controlled Drive pilot manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "acquired_at",
    "corpus",
    "authorization",
    "baseline_reconciliation",
    "exclusion_rules",
    "sources"
  ],
  "properties": {
    "manifest_version": { "const": "drive-pilot-v1" },
    "acquired_at": { "type": "string", "format": "date" },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["folder_locator_sha256", "folder_name", "owner_role", "authorized_role"],
      "properties": {
        "folder_locator_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "folder_name": { "const": "math4people" },
        "owner_role": { "const": "participant_corpus_owner" },
        "authorized_role": { "const": "codex_research_account" }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scope", "granted_on", "public_redistribution"],
      "properties": {
        "status": { "const": "confirmed" },
        "scope": { "const": "private_research_analysis" },
        "granted_on": { "type": "string", "format": "date" },
        "public_redistribution": { "const": false }
      }
    },
    "baseline_reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry_rows", "raw_files_present", "status", "missing_files"],
      "properties": {
        "registry_rows": { "const": 83 },
        "raw_files_present": { "const": 82 },
        "status": { "const": "reconciled_one_missing" },
        "missing_files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "exclusion_rules": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "sources": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "legacy_candidate_id",
        "title",
        "scope_entity_ids",
        "drive",
        "origin",
        "analysis_status",
        "extraction_status",
        "publication_status",
        "evidence_claims",
        "relationship_claims"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^source:[a-z0-9][a-z0-9:_-]*$"
        },
        "legacy_candidate_id": {
          "oneOf": [
            { "type": "string", "pattern": "^source:[a-z0-9][a-z0-9:_-]*$" },
            { "type": "null" }
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "scope_entity_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(person|event|institute):[a-z0-9][a-z0-9_-]*$"
          }
        },
        "drive": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "file_locator_sha256",
            "parent_locator_sha256",
            "mime_type",
            "size_bytes",
            "modified_time",
            "raw_sha256",
            "access_status"
          ],
          "properties": {
            "file_locator_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "parent_locator_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "mime_type": { "const": "application/pdf" },
            "size_bytes": { "type": "integer", "minimum": 1 },
            "modified_time": { "type": "string", "format": "date-time" },
            "raw_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "access_status": { "const": "writer_confirmed" }
          }
        },
        "origin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["publisher", "canonical_url", "rights_status", "rights_url", "rights_note"],
          "properties": {
            "publisher": { "type": "string", "minLength": 1 },
            "canonical_url": {
              "oneOf": [
                { "type": "string", "format": "uri", "pattern": "^https://" },
                { "type": "null" }
              ]
            },
            "rights_status": { "enum": ["cc_by_4_0", "rights_review_required"] },
            "rights_url": {
              "oneOf": [
                { "type": "string", "format": "uri", "pattern": "^https://" },
                { "type": "null" }
              ]
            },
            "rights_note": { "type": "string", "minLength": 1 }
          }
        },
        "analysis_status": { "const": "authorized_hash_verified" },
        "extraction_status": { "const": "pending_page_preserving_extraction" },
        "publication_status": {
          "enum": ["rights_review_required", "license_verified_extraction_pending"]
        },
        "evidence_claims": { "const": 0 },
        "relationship_claims": { "const": 0 }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "publication_status": { "const": "license_verified_extraction_pending" }
            },
            "required": ["publication_status"]
          },
          "then": {
            "properties": {
              "origin": {
                "properties": {
                  "rights_status": { "const": "cc_by_4_0" },
                  "canonical_url": { "type": "string", "pattern": "^https://" },
                  "rights_url": { "type": "string", "pattern": "^https://" }
                }
              }
            }
          }
        }
      ]
    }
  }
}
